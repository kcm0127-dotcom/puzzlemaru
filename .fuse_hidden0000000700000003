<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>2048 게임 무료 — 설치 없이 바로 하기 | 퍼즐마루</title>
<meta name="description" content="2048 퍼즐 게임을 브라우저에서 무료로. 방향키나 스와이프로 타일을 밀어 같은 숫자를 합치고 2048을 만들어 보세요. 최고 점수 자동 저장.">
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🧩</text></svg>">
<link rel="stylesheet" href="style.css">
<style>
#stage {
  position: relative; max-width: 420px; margin: 0 auto;
  background: #bbada0; border-radius: 10px; padding: 10px; touch-action: none;
}
#cells { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
#cells div { aspect-ratio: 1; background: rgba(238,228,218,.35); border-radius: 6px; }
#tiles { position: absolute; inset: 10px; }
.tile {
  position: absolute; display: flex; align-items: center; justify-content: center;
  font-weight: 700; border-radius: 6px;
  transition: left .12s ease, top .12s ease;
  width: var(--ts); height: var(--ts);
}
.pop { animation: pop .15s ease; }
@keyframes pop { 0% { transform: scale(.6); } 100% { transform: scale(1); } }
</style>
</head>
<body>
<header class="site">
  <div class="nav-wrap">
    <a class="logo" href="index.html">퍼즐<span>마루</span></a>
    <nav class="main">
      <a href="sudoku.html">스도쿠</a>
      <a href="minesweeper.html">지뢰찾기</a>
      <a href="2048.html" class="active">2048</a>
      <a href="omok.html">오목</a>
      <a href="guide-sudoku.html">공략</a>
    </nav>
  </div>
</header>
<main>
  <h1>2048 게임</h1>
  <p class="sub">방향키(PC) 또는 스와이프(모바일)로 타일을 밀어 같은 숫자를 합치세요. 목표는 2048!</p>

  <div class="toolbar">
    <button class="primary" id="reset">새 게임</button>
    <span class="stat">점수 <b id="score">0</b></span>
    <span class="stat">최고 <b id="best">0</b></span>
  </div>

  <div id="stage">
    <div id="cells"></div>
    <div id="tiles"></div>
  </div>
  <p class="msg" id="msg"></p>

  <div class="ad-slot">광고 영역 (AdSense)</div>

  <h2>2048 잘하는 법</h2>
  <p>가장 큰 타일을 한쪽 구석(예: 왼쪽 아래)에 고정하고, 그 구석을 비우는 방향으로는 절대 밀지 않는 것이 기본 전략입니다. 큰 타일 옆에 다음 크기 타일을 계단처럼 쌓아 두면 연쇄 합치기가 쉬워져요.</p>
</main>
<footer class="site">
  <div><a href="index.html">홈</a> · <a href="privacy.html">개인정보처리방침</a></div>
  <div style="margin-top:8px">© 2026 퍼즐마루</div>
</footer>
<script>
(function () {
  const COLORS = {
    2:["#eee4da","#776e65"],4:["#ede0c8","#776e65"],8:["#f2b179","#fff"],
    16:["#f59563","#fff"],32:["#f67c5f","#fff"],64:["#f65e3b","#fff"],
    128:["#edcf72","#fff"],256:["#edcc61","#fff"],512:["#edc850","#fff"],
    1024:["#edc53f","#fff"],2048:["#edc22e","#fff"]
  };
  let grid, score, best, over, won, idSeq;
  let tiles; // id -> {v, r, c, el}

  const cellsEl = document.getElementById("cells");
  for (let i = 0; i < 16; i++) cellsEl.appendChild(document.createElement("div"));

  function tileSize() {
    return (document.getElementById("stage").clientWidth - 20 - 30) / 4;
  }
  function pos(rc) { return rc * (tileSize() + 10); }

  function newTileEl(t) {
    const el = document.createElement("div");
    el.className = "tile pop";
    t.el = el;
    styleTile(t);
    document.getElementById("tiles").appendChild(el);
  }
  function styleTile(t) {
    const [bg, fg] = COLORS[t.v] || ["#3c3a32", "#fff"];
    const ts = tileSize();
    t.el.style.setProperty("--ts", ts + "px");
    t.el.style.background = bg;
    t.el.style.color = fg;
    t.el.style.fontSize = (t.v >= 1024 ? ts * .3 : t.v >= 128 ? ts * .36 : ts * .42) + "px";
    t.el.style.left = pos(t.c) + "px";
    t.el.style.top = pos(t.r) + "px";
    t.el.textContent = t.v;
  }

  function spawn() {
    const empty = [];
    for (let r = 0; r < 4; r++) for (let c = 0; c < 4; c++) {
      if (!grid[r][c]) empty.push([r, c]);
    }
    if (!empty.length) return;
    const [r, c] = empty[Math.floor(Math.random() * empty.length)];
    const t = { id: idSeq++, v: Math.random() < 0.9 ? 2 : 4, r, c };
    grid[r][c] = t;
    tiles.set(t.id, t);
    newTileEl(t);
  }

  function reset() {
    document.getElementById("tiles").innerHTML = "";
    grid = Array.from({ length: 4 }, () => [null, null, null, null]);
    tiles = new Map(); idSeq = 1; score = 0; over = false; won = false;
    best = Number(localStorage.getItem("best2048") || 0);
    updateScore();
    document.getElementById("msg").textContent = "";
    document.getElementById("msg").className = "msg";
    spawn(); spawn();
  }

  function updateScore() {
    document.getElementById("score").textContent = score;
    if (score > best) { best = score; localStorage.setItem("best2048", best); }
    document.getElementById("best").textContent = best;
  }

  function move(dr, dc) {
    if (over) return;
    let moved = false;
    const range = [0, 1, 2, 3];
    const rs = dr === 1 ? [3,2,1,0] : range;
    const cs = dc === 1 ? [3,2,1,0] : range;
    const mergedIds = new Set();
    for (const r of rs) for (const c of cs) {
      const t = grid[r][c];
      if (!t) continue;
      let nr = r, nc = c;
      while (true) {
        const tr = nr + dr, tc = nc + dc;
        if (tr < 0 || tr > 3 || tc < 0 || tc > 3) break;
        const occ = grid[tr][tc];
        if (!occ) { nr = tr; nc = tc; continue; }
        if (occ.v === t.v && !mergedIds.has(occ.id) && !mergedIds.has(t.id)) {
          nr = tr; nc = tc;
        }
        break;
      }
      if (nr === r && nc === c) continue;
      moved = true;
      const target = grid[nr][nc];
      grid[r][c] = null;
      if (target) {
        // merge
        mergedIds.add(target.id);
        target.v *= 2;
        score += target.v;
        grid[nr][nc] = target;
        t.r = nr; t.c = nc; styleTile(t);
        const dead = t;
        setTimeout(() => { dead.el.remove(); }, 120);
        tiles.delete(t.id);
        setTimeout(() => { styleTile(target); target.el.classList.remove("pop"); void target.el.offsetWidth; target.el.classList.add("pop"); }, 120);
        if (target.v === 2048 && !won) {
          won = true;
          const m = document.getElementById("msg");
          m.textContent = "🎉 2048 달성! 계속해서 더 큰 타일에 도전하세요.";
          m.className = "msg win";
        }
      } else {
        grid[nr][nc] = t;
        t.r = nr; t.c = nc; styleTile(t);
      }
    }
    if (moved) {
      updateScore();
      setTimeout(() => {
        spawn();
        if (!canMove()) {
          over = true;
          const m = document.getElementById("msg");
          m.textContent = "😢 더 움직일 수 없어요. 게임 오버! 점수: " + score;
          m.className = "msg lose";
        }
      }, 130);
    }
  }

  function canMove() {
    for (let r = 0; r < 4; r++) for (let c = 0; c < 4; c++) {
      if (!grid[r][c]) return true;
      const v = grid[r][c].v;
      if (r < 3 && grid[r+1][c] && grid[r+1][c].v === v) return true;
      if (c < 3 && grid[r][c+1] && grid[r][c+1].v === v) return true;
    }
    return false;
  }

  document.addEventListener("keydown", (e) => {
    const map = { ArrowUp:[-1,0], ArrowDown:[1,0], ArrowLeft:[0,-1], ArrowRight:[0,1] };
    if (map[e.key]) { e.preventDefault(); move(...map[e.key]); }
  });

  let sx = 0, sy = 0;
  const stage = document.getElementById("stage");
  stage.addEventListener("touchstart", (e) => {
    sx = e.touches[0].clientX; sy = e.touches[0].clientY;
  }, { passive: true });
  stage.addEventListener("touchend", (e) => {
    const dx = e.changedTouches[0].clientX - sx;
    const dy = e.changedTouches[0].clientY - sy;
    if (Math.max(Math.abs(dx), Math.abs(dy)) < 24) return;
    if (Math.abs(dx) > Math.abs(dy)) move(0, dx > 0 ? 1 : -1);
    else move(dy > 0 ? 1 : -1, 0);
  });

  window.addEventListener("resize", () => { tiles.forEach(styleTile); });
  document.getElementById("reset").addEventListener("click", reset);
  reset();
})();
</script>
</body>
</html>
